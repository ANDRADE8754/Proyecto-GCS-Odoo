<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- list VIEW -->
    <record id="view_techstore_equipo_list" model="ir.ui.view">
        <field name="name">techstore.equipo.list</field>
        <field name="model">techstore.equipo</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cliente_id"/>
                <field name="tipo_equipo"/>
                <field name="marca"/>
                <field name="modelo"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_techstore_equipo_form" model="ir.ui.view">
        <field name="name">techstore.equipo.form</field>
        <field name="model">techstore.equipo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="cliente_id"/>
                        <field name="tipo_equipo"/>
                        <field name="marca"/>
                        <field name="modelo"/>
                        <field name="serial"/>
                        <field name="estado"/>
                        <field name="observaciones"/>
                    </group>

                    <notebook>
                        <page string="Mantenimientos">
                            <field name="mantenimiento_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="fecha_ingreso"/>
                                    <field name="estado"/>
                                    <field name="costo"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_techstore_equipo" model="ir.actions.act_window">
        <field name="name">Equipos</field>
        <field name="res_model">techstore.equipo</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_techstore_root"
              name="TechStore"/>

    <menuitem id="menu_techstore_equipos"
              name="Equipos"
              parent="menu_techstore_root"
              action="action_techstore_equipo"/>

</odoo>