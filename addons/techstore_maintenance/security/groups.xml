<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
 
        <record id="module_category_techstore" model="ir.module.category">
            <field name="name">TechStore Mantenimiento</field>
            <field name="sequence">10</field>
        </record>
 
        <record id="group_techstore_admin" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_techstore"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
 
        <record id="group_techstore_manager" model="res.groups">
            <field name="name">Jefe Tecnico</field>
            <field name="category_id" ref="module_category_techstore"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
 
        <record id="group_techstore_technician" model="res.groups">
            <field name="name">Tecnico</field>
            <field name="category_id" ref="module_category_techstore"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
 
        <record id="group_techstore_receptionist" model="res.groups">
            <field name="name">Recepcionista</field>
            <field name="category_id" ref="module_category_techstore"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
 
    </data>
</odoo>