<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_techstore_mantenimiento_estado_wizard_form" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.estado.wizard.form</field>
            <field name="model">techstore.mantenimiento.estado.wizard</field>
            <field name="arch" type="xml">
                <form string="Cambiar Estado">
                    <sheet>
                        <group>
                            <field name="mantenimiento_id" readonly="1"/>
                            <field name="estado_objetivo" readonly="1" invisible="1"/>
                            <field name="tecnico_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="justificacion" placeholder="Explica por qué se realiza este cambio de estado..."/>
                            <field name="pruebas" placeholder="Describe las pruebas realizadas..."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirmar" type="object" string="Confirmar" class="btn-primary"/>
                        <button string="Cancelar" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>