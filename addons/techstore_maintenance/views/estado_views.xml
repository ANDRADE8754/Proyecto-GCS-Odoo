<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista Tree para techstore.estado -->
        <record id="view_techstore_estado_tree" model="ir.ui.view">
            <field name="name">techstore.estado.tree</field>
            <field name="model">techstore.estado</field>
            <field name="arch" type="xml">
                <tree string="Estados" edit="bottom">
                    <field name="id_estado"/>
                    <field name="nombre_estado"/>
                    <field name="secuencia" widget="handle"/>
                    <field name="es_estado_final"/>
                </tree>
            </field>
        </record>

        <!-- Vista Form para techstore.estado -->
        <record id="view_techstore_estado_form" model="ir.ui.view">
            <field name="name">techstore.estado.form</field>
            <field name="model">techstore.estado</field>
            <field name="arch" type="xml">
                <form string="Estado">
                    <sheet>
                        <h1>
                            <field name="nombre_estado" required="1"/>
                        </h1>
                        <group>
                            <group string="Información">
                                <field name="id_estado" required="1"/>
                                <field name="secuencia" required="1"/>
                                <field name="es_estado_final" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista Search para techstore.estado -->
        <record id="view_techstore_estado_search" model="ir.ui.view">
            <field name="name">techstore.estado.search</field>
            <field name="model">techstore.estado</field>
            <field name="arch" type="xml">
                <search string="Buscar Estados">
                    <field name="id_estado" filter_domain="[('id_estado', 'ilike', self)]"/>
                    <field name="nombre_estado" filter_domain="[('nombre_estado', 'ilike', self)]"/>
                    <separator/>
                    <filter name="filter_final" string="Estados Finales"
                            domain="[('es_estado_final', '=', True)]"/>
                    <filter name="filter_no_final" string="Estados en Progreso"
                            domain="[('es_estado_final', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Acción para abrir la lista de estados -->
        <record id="action_techstore_estado" model="ir.actions.act_window">
            <field name="name">Estados de Mantenimiento</field>
            <field name="res_model">techstore.estado</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_techstore_estado_search"/>
        </record>
    </data>
</odoo>
