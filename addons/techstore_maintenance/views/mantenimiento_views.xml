<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_techstore_close_form" model="ir.actions.client">
            <field name="name">Cerrar formulario</field>
            <field name="tag">techstore_close_form</field>
        </record>

        <record id="view_techstore_mantenimiento_tree" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.tree</field>
            <field name="model">techstore.mantenimiento</field>
            <field name="arch" type="xml">
                <tree string="Mantenimientos" decoration-danger="esta_retrasado" decoration-info="es_estado_final" banner_route="/techstore_maintenance/dashboard_banner">
                    <field name="id_mantenimiento"/>
                    <field name="ced_cliente"/>
                    <field name="id_equipo"/>
                    <field name="ced_tecnico"/>
                    <field name="id_prioridad"/>
                    <field name="id_estado" options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="fecha_ingreso"/>
                    <field name="fecha_estimada_entrega"/>
                    <field name="esta_retrasado" invisible="1"/>
                    <field name="es_estado_final" invisible="1"/>
                </tree>
            </field>
        </record>

        <record id="view_techstore_mantenimiento_form" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.form</field>
            <field name="model">techstore.mantenimiento</field>
            <field name="arch" type="xml">
                <form string="Mantenimiento">
                    <header>
                        <field name="puede_pasar_diagnostico" invisible="1"/>
                        <field name="puede_pasar_reparacion" invisible="1"/>
                        <field name="puede_pasar_esperando_repuestos" invisible="1"/>
                        <field name="puede_pasar_control_calidad" invisible="1"/>
                        <field name="puede_pasar_listo_entrega" invisible="1"/>
                        <field name="puede_pasar_entregado" invisible="1"/>
                        <button string="Guardar" special="save" class="btn-primary oe_highlight"/>
                        <button string="Cancelar" special="cancel" class="btn-secondary"/>
                        <!-- Recepcionista/Jefe Técnico/Gerencia: Pasar a Diagnóstico -->
                        <button name="action_set_diagnostico" type="object" string="→ Diagnóstico" class="btn-primary"
                                groups="techstore_maintenance.techstore_group_receptionist,techstore_maintenance.techstore_group_technical_boss,techstore_maintenance.techstore_group_manager"/>
                        <!-- Técnico/Jefe Técnico: Pasar a Reparación -->
                        <button name="action_set_reparacion" type="object" string="→ Reparación" class="btn-primary"
                                groups="techstore_maintenance.techstore_group_technician,techstore_maintenance.techstore_group_technical_boss,techstore_maintenance.techstore_group_manager"/>
                        <!-- Técnico: Marcar Esperando Repuestos -->
                        <button name="action_set_esperando_repuestos" type="object" string="⏸ Esperando Repuestos" class="btn-warning"
                                groups="techstore_maintenance.techstore_group_technician,techstore_maintenance.techstore_group_technical_boss,techstore_maintenance.techstore_group_manager"/>
                        <!-- Jefe Técnico/Gerencia: Control de Calidad -->
                        <button name="action_set_control_calidad" type="object" string="→ Control de Calidad" class="btn-info"
                                groups="techstore_maintenance.techstore_group_technical_boss,techstore_maintenance.techstore_group_manager"/>
                        <!-- Jefe Técnico/Gerencia: Listo para Entrega -->
                        <button name="action_set_listo_entrega" type="object" string="✓ Listo para Entrega" class="btn-success"
                                groups="techstore_maintenance.techstore_group_technical_boss,techstore_maintenance.techstore_group_manager"/>
                        <!-- Recepcionista/Gerencia: Entregar -->
                        <button name="action_set_entregado" type="object" string="✓ Entregar al Cliente" class="btn-success"
                                groups="techstore_maintenance.techstore_group_receptionist,techstore_maintenance.techstore_group_manager"/>
                    </header>
                    <sheet>
                        <field name="puede_modificar_datos_iniciales" invisible="1"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_cliente" type="object" class="oe_stat_button oe_stat_button_green" icon="fa-user">
                                <field name="ced_cliente" widget="statinfo" string="Cliente" readonly="1"/>
                            </button>
                            <button name="action_view_equipo" type="object" class="oe_stat_button oe_stat_button_blue" icon="fa-laptop">
                                <field name="id_equipo" widget="statinfo" string="Equipo" readonly="1"/>
                            </button>
                            <button name="action_view_tecnico" type="object" class="oe_stat_button oe_stat_button_blue" icon="fa-user-cog">
                                <field name="ced_tecnico" widget="statinfo" string="Técnico" readonly="1"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <span>Mantenimiento</span>
                                <field name="id_mantenimiento" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <field name="id_estado" readonly="1"/>
                            <field name="puede_pasar_diagnostico" invisible="1"/>
                            <field name="puede_pasar_reparacion" invisible="1"/>
                            <field name="puede_pasar_esperando_repuestos" invisible="1"/>
                            <field name="puede_pasar_control_calidad" invisible="1"/>
                            <field name="puede_pasar_listo_entrega" invisible="1"/>
                            <field name="puede_pasar_entregado" invisible="1"/>
                            <field name="es_tecnico_jefe" invisible="1"/>
                            <field name="es_recepcionista" invisible="1"/>
                            <field name="es_administrador" invisible="1"/>
                            <field name="es_gerencia" invisible="1"/>
                            <group string="Datos del Servicio">
                                <field name="ced_cliente" required="1" options="{'no_create': True, 'no_create_edit': True}" readonly="0"/>
                                <field name="id_equipo" required="1" domain="[('ced_cliente', '=', ced_cliente)]" options="{'no_create': True, 'no_create_edit': True}" readonly="0" context="{'default_ced_cliente': ced_cliente}"/>
                                <field name="ced_tecnico" options="{'no_create': True}"/>
                                <field name="id_prioridad" required="1" options="{'no_create': True}" readonly="0"/>
                            </group>
                            <group string="Estado">
                                <field name="id_estado" readonly="1" widget="statusbar" statusbar_visible="nuevo,diagnostico,reparacion,esperando_repuestos,control_calidad,listo_entrega,entregado" options="{'no_create': True, 'no_create_edit': True}" nolabel="1" colspan="2"/>
                            </group>
                            <group string="Fechas y Control">
                                <field name="fecha_ingreso" readonly="1"/>
                                <field name="fecha_estimada_entrega" readonly="1"/>
                                <field name="fecha_entrega"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Falla Reportada">
                                <group>
                                    <field name="falla_reportada" placeholder="Describe la falla reportada por el cliente..." readonly="0"/>
                                    <field name="descripcion_problema" placeholder="Resume la evaluación inicial..."/>
                                </group>
                            </page>
                            <page string="Diagnóstico y Solución">
                                <group>
                                    <field name="diagnostico" placeholder="Ingresa el diagnóstico técnico..."/>
                                    <field name="solucion" placeholder="Describe la solución aplicada..."/>
                                </group>
                            </page>
                            <page string="Cambios de Estado">
                                <group>
                                    <field name="justificacion_cambio_estado" placeholder="Justificación del cambio de estado..." readonly="1"/>
                                    <field name="pruebas_cambio_estado" placeholder="Pruebas realizadas al cambiar de estado..." readonly="1"/>
                                </group>
                            </page>
                            <page string="Seguimiento" invisible="0">
                                <group>
                                    <field name="id_mantenimiento" readonly="1"/>
                                    <field name="fecha_ingreso" readonly="1"/>
                                    <field name="fecha_estimada_entrega" readonly="1"/>
                                    <field name="esta_retrasado" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_techstore_mantenimiento_kanban" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.kanban</field>
            <field name="model">techstore.mantenimiento</field>
            <field name="arch" type="xml">
                <kanban default_group_by="id_estado" class="o_kanban_small_column" quick_create="false" group_create="false" draggable="false" banner_route="/techstore_maintenance/dashboard_banner">
                    <field name="id_estado" options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="id_prioridad"/>
                    <field name="ced_cliente"/>
                    <field name="id_equipo"/>
                    <field name="ced_tecnico"/>
                    <field name="esta_retrasado"/>
                    <field name="fecha_ingreso"/>
                    <templates>
                            <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <h4 class="o_kanban_record_title">
                                        <field name="id_mantenimiento"/>
                                    </h4>
                                    <div class="o_kanban_record_body">
                                        <p><strong>Cliente:</strong> <field name="ced_cliente"/></p>
                                        <p><strong>Equipo:</strong> <field name="id_equipo"/></p>
                                        <p><strong>Prioridad:</strong> <field name="id_prioridad"/></p>
                                        <p><strong>Técnico:</strong> <field name="ced_tecnico"/></p>
                                        <t t-if="record.esta_retrasado.raw_value">
                                            <p><span class="badge badge-danger">Retrasado</span></p>
                                        </t>
                                        <p><small class="text-muted">Ingreso: <field name="fecha_ingreso"/></small></p>
                                    </div>
                                </div>
                                <div class="o_kanban_footer">
                                    <button type="object" name="action_set_diagnostico" class="btn btn-sm btn-primary" string="Mover a Diagnóstico"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_techstore_mantenimiento_search" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.search</field>
            <field name="model">techstore.mantenimiento</field>
            <field name="arch" type="xml">
                <search string="Buscar Mantenimientos">
                    <field name="id_mantenimiento"/>
                    <field name="ced_cliente"/>
                    <field name="id_equipo"/>
                    <field name="ced_tecnico"/>
                    <field name="id_estado"/>
                    <field name="id_prioridad"/>
                    <separator/>
                    <filter name="filter_nuevo" string="Nuevos" domain="[('nombre_estado', '=', 'nuevo')]"/>
                    <filter name="filter_diagnostico" string="En Diagnóstico" domain="[('nombre_estado', '=', 'diagnostico')]"/>
                    <filter name="filter_reparacion" string="En Reparación" domain="[('nombre_estado', '=', 'reparacion')]"/>
                    <filter name="filter_esperando" string="Esperando Repuestos" domain="[('nombre_estado', '=', 'esperando_repuestos')]"/>
                    <filter name="filter_control_calidad" string="Control de Calidad" domain="[('nombre_estado', '=', 'control_calidad')]"/>
                    <filter name="filter_listo_entrega" string="Listo para Entrega" domain="[('nombre_estado', '=', 'listo_entrega')]"/>
                    <filter name="filter_entregado" string="Entregados" domain="[('nombre_estado', '=', 'entregado')]"/>
                    <separator/>
                    <filter name="filter_retrasado" string="Retrasados" domain="[('esta_retrasado', '=', True)]"/>
                    <filter name="filter_sin_tecnico" string="Sin Técnico" domain="[('ced_tecnico', '=', False)]"/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_by_estado" string="Estado" context="{'group_by': 'id_estado'}"/>
                        <filter name="group_by_cliente" string="Cliente" context="{'group_by': 'ced_cliente'}"/>
                        <filter name="group_by_tecnico" string="Técnico" context="{'group_by': 'ced_tecnico'}"/>
                        <filter name="group_by_prioridad" string="Prioridad" context="{'group_by': 'id_prioridad'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Vista Pivot (Cubo Analítico) -->
        <record id="view_techstore_mantenimiento_pivot" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.pivot</field>
            <field name="model">techstore.mantenimiento</field>
            <field name="arch" type="xml">
                <pivot string="Análisis de Mantenimientos" sample="1">
                    <field name="ced_tecnico" type="row"/>
                    <field name="id_estado" type="col"/>
                    <field name="tiempo_atencion_horas" type="measure"/>
                    <field name="esta_retrasado" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Vista Graph (Gráficos) -->
        <record id="view_techstore_mantenimiento_graph" model="ir.ui.view">
            <field name="name">techstore.mantenimiento.graph</field>
            <field name="model">techstore.mantenimiento</field>
            <field name="arch" type="xml">
                <graph string="Análisis de Mantenimientos" type="bar" sample="1">
                    <field name="ced_tecnico" type="row"/>
                    <field name="id_estado" type="col"/>
                </graph>
            </field>
        </record>

        <record id="action_techstore_mantenimiento" model="ir.actions.act_window">
            <field name="name">Mantenimientos</field>
            <field name="res_model">techstore.mantenimiento</field>
            <field name="view_mode">kanban,tree,form,pivot,graph</field>
            <field name="search_view_id" ref="view_techstore_mantenimiento_search"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crea una nueva orden de mantenimiento.</p>
            </field>
        </record>

        <record id="action_techstore_mantenimiento_receptionist" model="ir.actions.act_window">
            <field name="name">Mantenimientos Nuevos</field>
            <field name="res_model">techstore.mantenimiento</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_techstore_mantenimiento_search"/>
            <field name="domain">[('nombre_estado', '=', 'nuevo')]</field>
            <field name="context">{'search_default_filter_nuevo': 1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Crea un nuevo mantenimiento desde recepción.</p>
            </field>
        </record>

        <record id="action_techstore_mantenimiento_form" model="ir.actions.act_window">
            <field name="name">Nuevo Mantenimiento</field>
            <field name="res_model">techstore.mantenimiento</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_techstore_mantenimiento_form"/>
            <field name="target">current</field>
        </record>
    </data>
</odoo>