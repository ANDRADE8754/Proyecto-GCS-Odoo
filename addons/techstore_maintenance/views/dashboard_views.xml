<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
 
    <record id="action_techstore_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard de Mantenimientos</field>
        <field name="res_model">techstore.maintenance.order</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{
            'search_default_filter_active': 1,
            'graph_measure': '__count',
        }</field>
    </record>
 
    <record id="action_my_techstore_orders" model="ir.actions.act_window">
        <field name="name">Mis Trabajos</field>
        <field name="res_model">techstore.maintenance.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('technician_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>
 
    </data>
</odoo>